{
  "name": "z3r0-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "generate:api": "openapi-typescript ./openapi.json -o ./src/shared/api/generated/schema.ts",
    "typecheck": "tsc --noEmit",
